						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/slots/generate?doctorId={{doctor_id}}&date=2026-05-25&startTime=09:00:00&endTime=17:00:00&slotDurationMinutes=30",
							"host": ["{{base_url}}"],
							"path": ["api", "slots", "generate"],
							"query": [
								{
									"key": "doctorId",
									"value": "{{doctor_id}}"
								},
