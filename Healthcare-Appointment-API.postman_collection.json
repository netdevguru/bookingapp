				{
					"name": "Generate Slots for Doctor",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.length > 0 && jsonData[0].id) {",
									"        pm.collectionVariables.set('slot_id', jsonData[0].id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
